---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Hero from "../components/Hero.astro";
import Oferta from "../components/Oferta.astro";
import Obszar from "../components/Obszar.astro";
import Jak from "../components/Jak.astro";
import OSkupie from "../components/OSkupie.astro";
import Faq from "../components/Faq.astro";
import Cta from "../components/Cta.astro";
---

<Layout>
  <div style="position:relative;width:100%;background:#0c0c0d">
    <Nav />
    <Hero />
    <Oferta />
    <Obszar />
    <Jak />
    <OSkupie />
    <Faq />
    <Cta />
  </div>
</Layout>

<script>
  // Reveal: pokaż elementy, gdy wejdą w widok
  const reveals = document.querySelectorAll<HTMLElement>("[data-reveal]");
  if ("IntersectionObserver" in window) {
    const io = new IntersectionObserver(
      (entries) => {
        for (const e of entries) {
          if (e.isIntersecting) {
            e.target.classList.add("is-visible");
            io.unobserve(e.target);
          }
        }
      },
      { threshold: 0.18 },
    );
    reveals.forEach((el) => io.observe(el));
  } else {
    reveals.forEach((el) => el.classList.add("is-visible"));
  }

  // Poziomy "pinned scroll" + pasek postępu + parallax — throttle przez rAF
  const bar = document.getElementById("js-progress");
  const wrap = document.getElementById("skup");
  const track = document.querySelector<HTMLElement>(".skup-track");
  const photo = document.querySelector<HTMLElement>(".obszar-photo");

  let scrollLen = 0;
  let ticking = false;

  function layout() {
    if (!track || !wrap) return;
    scrollLen = Math.max(0, track.scrollWidth - window.innerWidth + 40);
    wrap.style.height = window.innerHeight + scrollLen + "px";
  }

  function update() {
    ticking = false;
    const doc = document.documentElement;
    const max = doc.scrollHeight - window.innerHeight || 1;
    const sy = window.scrollY || doc.scrollTop;

    if (bar) bar.style.transform = "scaleX(" + Math.min(1, sy / max) + ")";

    if (wrap && track) {
      const top = wrap.getBoundingClientRect().top;
      const prog = Math.min(1, Math.max(0, -top / (scrollLen || 1)));
      track.style.transform = "translate3d(" + -prog * scrollLen + "px,0,0)";
    }

    if (photo) {
      const sec = photo.closest("section");
      if (sec) photo.style.transform = "translateY(" + sec.getBoundingClientRect().top * -0.1 + "px)";
    }
  }

  function onScroll() {
    if (!ticking) {
      ticking = true;
      requestAnimationFrame(update);
    }
  }

  window.addEventListener("scroll", onScroll, { passive: true });
  window.addEventListener("resize", () => {
    layout();
    onScroll();
  });

  layout();
  update();
  // ponowny layout, gdy fonty się załadują (zmienia szerokość treści)
  if (document.fonts && document.fonts.ready) {
    document.fonts.ready.then(() => {
      layout();
      update();
    });
  }
</script>
