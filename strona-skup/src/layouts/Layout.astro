---
// Self-hosted fonts (tylko używane grubości) — bez render-blocking z Google CDN
import "@fontsource/space-grotesk/400.css";
import "@fontsource/space-grotesk/500.css";
import "@fontsource/space-grotesk/600.css";
import "@fontsource/space-grotesk/700.css";
import "@fontsource/jetbrains-mono/400.css";
import "@fontsource/jetbrains-mono/500.css";
import "@fontsource/jetbrains-mono/700.css";

const localBusinessJsonLd = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  name: "Skup Bydła z Konieczności",
  description:
    "Skup bydła na ubój z konieczności: krowy, byki, jałówki i cielęta, a także maciory, knury, owce i kozy. Odbiór w dniu zgłoszenia, płatność gotówką, faktura VAT, wyrejestrowanie i formalności po naszej stronie.",
  image: "/uploads/bydlo.jpg",
  telephone: ["+48508869814", "+48508230575"],
  areaServed: [
    { "@type": "AdministrativeArea", name: "Mazowieckie" },
    { "@type": "AdministrativeArea", name: "Podlaskie" },
    { "@type": "AdministrativeArea", name: "Warmińsko-mazurskie" },
    { "@type": "AdministrativeArea", name: "Kujawsko-pomorskie" },
    { "@type": "AdministrativeArea", name: "Łódzkie" },
    { "@type": "AdministrativeArea", name: "Lubelskie" },
  ],
};

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "Czym jest skup bydła na ubój z konieczności?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Dotyczy zdrowego zwierzęcia, które uległo wypadkowi, na przykład złamało kończynę albo doznało urazu przy porodzie, i ze względu na dobrostan musi zostać szybko ubite. Odbieramy takie sztuki bezpośrednio z gospodarstwa.",
      },
    },
    {
      "@type": "Question",
      name: "Jak szybko odbieracie zwierzę?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Odbieramy w dniu zgłoszenia. Działamy 7 dni w tygodniu, także w weekendy i święta, bo przy uboju z konieczności liczy się czas.",
      },
    },
    {
      "@type": "Question",
      name: "Czy zajmujecie się formalnościami i wyrejestrowaniem?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Tak. Bierzemy na siebie formalności związane ze zgłoszeniem zdarzenia i wyrejestrowaniem zwierzęcia. Wystawiamy fakturę VAT, a płatność realizujemy gotówką przy odbiorze.",
      },
    },
    {
      "@type": "Question",
      name: "Jakie zwierzęta skupujecie?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Bydło, czyli krowy, byki, jałówki i cielęta, a także maciory, knury oraz owce i kozy.",
      },
    },
    {
      "@type": "Question",
      name: "Na jakim terenie działacie?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Skupujemy w całych województwach: mazowieckim, podlaskim, warmińsko-mazurskim, kujawsko-pomorskim, łódzkim i lubelskim, łącznie z mniejszymi miejscowościami w tych regionach.",
      },
    },
  ],
};
---

<!doctype html>
<html lang="pl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <title>Skup bydła na ubój z konieczności | Odbiór w dniu zgłoszenia, gotówka</title>
    <meta
      name="description"
      content="Skup bydła na ubój z konieczności. Krowy, byki, jałówki i cielęta. Odbiór w dniu zgłoszenia, działamy 7 dni w tygodniu, płatność gotówką, faktura VAT, wyrejestrowanie i formalności po naszej stronie. Zadzwoń: 508 869 814."
    />
    <meta
      name="keywords"
      content="skup bydła na ubój z konieczności, skup bydła z konieczności, skup bydła, skup krów, skup byków, skup jałówek, skup cieląt, skup macior, skup knurów, ubój z konieczności, skup żywca"
    />
    <meta name="robots" content="index, follow" />
    <meta name="author" content="Skup Bydła z Konieczności" />
    <meta name="geo.region" content="PL" />
    <meta name="geo.placename" content="Polska" />

    <meta property="og:type" content="website" />
    <meta property="og:locale" content="pl_PL" />
    <meta property="og:title" content="Skup bydła na ubój z konieczności | Odbiór w dniu zgłoszenia" />
    <meta
      property="og:description"
      content="Skup bydła na ubój z konieczności. Odbiór w dniu zgłoszenia, 7 dni w tygodniu, gotówka, faktura VAT, wyrejestrowanie. Zadzwoń: 508 869 814."
    />
    <meta property="og:image" content="/uploads/bydlo.jpg" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Skup bydła na ubój z konieczności" />
    <meta
      name="twitter:description"
      content="Odbiór w dniu zgłoszenia, gotówka, faktura VAT, wyrejestrowanie. Zadzwoń: 508 869 814."
    />
    <meta name="twitter:image" content="/uploads/bydlo.jpg" />

    <script type="application/ld+json" set:html={JSON.stringify(localBusinessJsonLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  * {
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    background: #0c0c0d;
    color: #f5f4f1;
    font-family: "Space Grotesk", sans-serif;
    -webkit-font-smoothing: antialiased;
    overflow-x: hidden;
  }

  ::selection {
    background: #4d8b00;
    color: #fff;
  }

  a {
    color: inherit;
  }

  /* ===== Hover (zastępuje dawne style-hover z frameworka x-dc) ===== */
  .nav-menu-link:hover {
    color: #f5f4f1;
  }
  .nav-phone:hover {
    background: #e83232;
  }
  .btn-primary:hover {
    background: #e83232;
  }
  .btn-outline:hover {
    border-color: #4d8b00;
  }
  .cta-phone--solid:hover {
    background: #e83232;
  }
  .cta-phone--outline:hover {
    border-color: rgba(245, 244, 241, 0.85);
  }

  /* ===== Reveal (animacja wejścia) ===== */
  [data-reveal] {
    opacity: 0;
    transform: translateY(26px);
    transition:
      opacity 0.7s cubic-bezier(0.2, 0.7, 0.2, 1),
      transform 0.7s cubic-bezier(0.2, 0.7, 0.2, 1);
  }
  [data-reveal].is-visible {
    opacity: 1;
    transform: none;
  }
  @media (prefers-reduced-motion: reduce) {
    [data-reveal] {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }

  /* ===== MARQUEE (przewijany pasek powiatów/gmin) ===== */
  .marquee {
    position: relative;
    overflow: hidden;
    width: 100%;
    -webkit-mask-image: linear-gradient(90deg, transparent 0, #000 6%, #000 94%, transparent 100%);
    mask-image: linear-gradient(90deg, transparent 0, #000 6%, #000 94%, transparent 100%);
  }
  .marquee-track {
    display: flex;
    width: max-content;
    gap: 52px;
    animation: marquee 42s linear infinite;
  }
  .marquee:hover .marquee-track {
    animation-play-state: paused;
  }
  .marquee-chip {
    flex: 0 0 auto;
    white-space: nowrap;
    font: 500 16px "Space Grotesk", sans-serif;
    color: rgba(245, 244, 241, 0.6);
  }
  @keyframes marquee {
    to {
      transform: translateX(-50%);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .marquee-track {
      animation: none;
      flex-wrap: wrap;
      gap: 10px 28px;
    }
  }

  /* ===== FAQ (rozwijane pytania) ===== */
  .faq-item {
    border-top: 1px solid rgba(245, 244, 241, 0.12);
  }
  .faq-item:last-of-type {
    border-bottom: 1px solid rgba(245, 244, 241, 0.12);
  }
  .faq-item summary {
    list-style: none;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 18px;
    padding: 24px 0;
    font: 700 20px "Space Grotesk", sans-serif;
  }
  .faq-item summary::-webkit-details-marker {
    display: none;
  }
  .faq-item summary::after {
    content: "+";
    flex: 0 0 auto;
    font: 400 28px "Space Grotesk", sans-serif;
    line-height: 1;
    color: #4d8b00;
  }
  .faq-item[open] summary::after {
    content: "\2212";
  }
  .faq-item .faq-a {
    margin: 0;
    padding: 0 0 26px;
    max-width: 780px;
    font: 400 16px/1.7 "Space Grotesk", sans-serif;
    color: rgba(245, 244, 241, 0.7);
  }

  /* ===== Obrazy wstawiane przez <Image> jako tło sekcji/kart ===== */
  .bg-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* ===== MOBILE ===== */
  @media (max-width: 820px) {
    .nav {
      padding: 14px 20px !important;
    }
    .nav-links {
      gap: 14px !important;
    }
    .nav-menu-link {
      display: none !important;
    }
    .nav-phone {
      padding: 10px 15px !important;
      font-size: 12px !important;
    }

    .hero-img {
      display: none !important;
    }
    .hero-content {
      padding: 96px 22px 40px !important;
      justify-content: center !important;
    }
    .hero-phones {
      font-size: 17px !important;
    }
    .hero-cta {
      gap: 16px !important;
    }

    .skup-track {
      gap: 18px !important;
      padding: 0 22px !important;
    }
    .skup-intro {
      width: 80vw !important;
    }
    .skup-card {
      width: 76vw !important;
      height: 56vh !important;
      padding: 26px !important;
    }
    .skup-card h3 {
      font-size: 32px !important;
    }
    .skup-outro {
      width: 80vw !important;
      padding-right: 22px !important;
    }

    .obszar-content {
      padding: 90px 22px !important;
    }

    .seo-section {
      padding: 80px 22px 30px !important;
    }
    .seo-grid {
      grid-template-columns: 1fr !important;
      gap: 30px !important;
    }
    .faq-section {
      padding: 50px 22px 20px !important;
    }

    .jak-section {
      padding: 90px 22px 90px !important;
    }
    .jak-grid {
      grid-template-columns: 1fr !important;
    }
    .jak-grid > div {
      padding: 30px !important;
    }

    .cta-section {
      padding: 90px 22px 70px !important;
    }
    .cta-phone {
      padding: 18px 28px !important;
    }
  }
</style>
