---
import { Image } from "astro:assets";
import cardBydlo from "../assets/card-bydlo.jpg";
import cardMaciory from "../assets/card-maciory.jpg";
import cardKnury from "../assets/card-knury.jpg";
import cardOwce from "../assets/card-owce.jpg";

const cards = [
  { n: "01", title: "Bydło", img: cardBydlo, desc: "Krowy, byki, jałówki i cielęta na ubój z konieczności." },
  { n: "02", title: "Maciory", img: cardMaciory, desc: "Skup macior w każdej ilości, z odbiorem od Ciebie." },
  { n: "03", title: "Knury", img: cardKnury, desc: "Knury i trzoda, z wyceną i odbiorem w dniu zgłoszenia." },
  { n: "04", title: "Owce i kozy", img: cardOwce, desc: "Owce, kozy i drobny żywiec, także w małych ilościach." },
];

const cardStyle =
  "position:relative;flex:0 0 auto;width:420px;height:62vh;align-self:center;display:flex;flex-direction:column;justify-content:space-between;padding:34px;border:1px solid rgba(245,244,241,.1);border-radius:4px;overflow:hidden";
const overlayStyle =
  "position:absolute;inset:0;background:linear-gradient(180deg,rgba(12,12,13,.78) 0%,rgba(12,12,13,.34) 40%,rgba(12,12,13,.52) 62%,rgba(12,12,13,.93) 100%)";
---
<section id="skup" style="position:relative">
  <div style="position:sticky;top:0;height:100vh;overflow:hidden;display:flex;align-items:center">
    <div
      class="skup-track"
      style="display:flex;align-items:stretch;gap:32px;padding:0 40px;will-change:transform"
    >
      <div
        class="skup-intro"
        style="flex:0 0 auto;width:min(78vw,560px);display:flex;flex-direction:column;justify-content:center"
      >
        <span style="font:500 12px 'JetBrains Mono',monospace;letter-spacing:.14em;color:#4d8b00">OFERTA</span>
        <h2 style="margin:18px 0 0;font:700 clamp(44px,6vw,84px)/0.92 'Space Grotesk',sans-serif;letter-spacing:-0.02em">
          Co<br />skupujemy
        </h2>
        <p style="margin:24px 0 0;max-width:380px;font:400 16px/1.6 'Space Grotesk',sans-serif;color:rgba(245,244,241,.68)">
          Bydło i pozostały żywiec. Skup z konieczności, w całości, z odbiorem od Ciebie.
        </p>
      </div>

      {
        cards.map((c) => (
          <article class="skup-card" style={cardStyle}>
            <Image
              src={c.img}
              alt={`Skup: ${c.title}`}
              widths={[420, 840]}
              sizes="(max-width: 820px) 76vw, 420px"
              loading="lazy"
              class="bg-image"
            />
            <div style={overlayStyle} />
            <div style="position:relative;display:flex;justify-content:space-between;align-items:flex-start">
              <span style="font:700 64px 'JetBrains Mono',monospace;color:rgba(245,244,241,.55);line-height:1">
                {c.n}
              </span>
              <span style="width:54px;height:54px;border:1.4px dashed rgba(245,244,241,.22);border-radius:50%" />
            </div>
            <div style="position:relative">
              <h3 style="margin:0;font:700 40px 'Space Grotesk',sans-serif;letter-spacing:-0.01em">{c.title}</h3>
              <p style="margin:12px 0 0;font:400 15px/1.6 'Space Grotesk',sans-serif;color:rgba(245,244,241,.6)">
                {c.desc}
              </p>
            </div>
          </article>
        ))
      }

      <div
        class="skup-outro"
        style="flex:0 0 auto;width:min(72vw,460px);display:flex;flex-direction:column;justify-content:center;padding-right:40px"
      >
        <h3 style="margin:0;font:700 clamp(34px,4.5vw,56px)/1.0 'Space Grotesk',sans-serif;letter-spacing:-0.02em">
          Nie widzisz<br />swojego <span style="color:#4d8b00">żywca?</span>
        </h3>
        <p style="margin:20px 0 28px;font:400 16px/1.6 'Space Grotesk',sans-serif;color:rgba(245,244,241,.68)">
          Zadzwoń, a wycenimy i umówimy odbiór tego samego dnia.
        </p>
        <a
          href="tel:508869814"
          class="btn-primary"
          style="align-self:flex-start;background:#4d8b00;color:#fff;font:700 16px 'Space Grotesk',sans-serif;padding:16px 28px;border-radius:2px;text-decoration:none"
          >508 869 814</a
        >
      </div>
    </div>
  </div>
</section>
