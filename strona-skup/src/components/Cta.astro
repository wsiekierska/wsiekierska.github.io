---
---
<section
  class="cta-section"
  style="position:relative;border-top:1px solid rgba(245,244,241,.1);padding:120px 40px 80px;overflow:hidden"
>
  <div
    style="position:absolute;inset:0;background:radial-gradient(90% 120% at 50% 120%,rgba(132,195,55,.141) 0%,transparent 55%)"
  >
  </div>
  <div style="position:relative;z-index:2;max-width:1080px;margin:0 auto;text-align:center">
    <span
      data-reveal
      style="font:500 12px 'JetBrains Mono',monospace;letter-spacing:.14em;color:rgba(245,244,241,.6)"
      >SKUP Z KONIECZNOŚCI, BEZ CZEKANIA</span
    >
    <h2
      data-reveal
      style="margin:22px 0 40px;font:700 clamp(44px,7vw,104px)/0.9 'Space Grotesk',sans-serif;letter-spacing:-0.03em"
    >
      Zadzwoń <br />odbierzemy <span style="color:#4d8b00">dziś</span>
    </h2>
    <div data-reveal style="display:flex;gap:22px;justify-content:center;flex-wrap:wrap">
      <a
        href="tel:508869814"
        class="cta-phone cta-phone--solid"
        style="display:flex;flex-direction:column;align-items:flex-start;gap:4px;background:#4d8b00;color:#fff;padding:22px 38px;border-radius:3px;text-decoration:none"
      >
        <span style="font:500 11px 'JetBrains Mono',monospace;letter-spacing:.1em;opacity:.85">ZADZWOŃ</span>
        <span style="font:700 30px 'JetBrains Mono',monospace">508 869 814</span>
      </a>
      <a
        href="tel:508230575"
        class="cta-phone cta-phone--outline"
        style="display:flex;flex-direction:column;align-items:flex-start;gap:4px;border:1.5px solid rgba(245,244,241,.4);color:#f5f4f1;padding:22px 38px;border-radius:3px;text-decoration:none"
      >
        <span style="font:500 11px 'JetBrains Mono',monospace;letter-spacing:.1em;opacity:.7">LUB</span>
        <span style="font:700 30px 'JetBrains Mono',monospace">508 230 575</span>
      </a>
    </div>
  </div>

  <div
    style="position:relative;z-index:2;max-width:1280px;margin:96px auto 0;padding-top:30px;border-top:1px solid rgba(245,244,241,.1);display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:16px"
  >
    <div style="display:flex;align-items:center;gap:12px">
      <span
        style="width:30px;height:30px;border:1.5px solid rgba(245,244,241,.7);display:flex;align-items:center;justify-content:center;border-radius:2px;font:700 13px 'Space Grotesk',sans-serif"
        >B</span
      >
      <span style="font:700 13px 'Space Grotesk',sans-serif">Skup Bydła z Konieczności</span>
    </div>
    <span style="font:400 12px 'JetBrains Mono',monospace;color:rgba(245,244,241,.45)"
      >Płatne gotówką, faktura VAT, formalności po naszej stronie</span
    >
  </div>
</section>
