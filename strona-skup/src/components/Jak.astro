---
const steps = [
  {
    n: "01",
    title: "Odbiór w dniu zgłoszenia",
    desc: "Zgłaszasz, a my przyjeżdżamy. Bez zbędnego czekania i odkładania na przyszły tydzień.",
  },
  {
    n: "02",
    title: "7 dni w tygodniu",
    desc: "Jesteśmy dostępni także w weekendy i święta, gdy żywiec wymaga pilnego odbioru.",
  },
  {
    n: "03",
    title: "Gotówka i faktura VAT",
    desc: "Konkurencyjne ceny, płatność gotówką przy odbiorze, faktura VAT na miejscu.",
  },
  {
    n: "04",
    title: "Formalności po naszej stronie",
    desc: "Załatwiamy wszystkie formalności i wyrejestrowanie zwierzęcia z ARiMR.",
  },
];
---
<section id="jak" class="jak-section" style="max-width:1280px;margin:0 auto;padding:140px 40px 130px">
  <span data-reveal style="font:500 12px 'JetBrains Mono',monospace;letter-spacing:.14em;color:#4d8b00"
    >JAK DZIAŁAMY</span
  >
  <h2
    data-reveal
    style="margin:18px 0 64px;font:700 clamp(40px,6vw,80px)/0.92 'Space Grotesk',sans-serif;letter-spacing:-0.02em;max-width:820px"
  >
    Szybko, gotówką,<br />bez czekania
  </h2>
  <div
    class="jak-grid"
    style="display:grid;grid-template-columns:repeat(2,1fr);gap:1px;background:rgba(245,244,241,.1);border:1px solid rgba(245,244,241,.1)"
  >
    {
      steps.map((s) => (
        <div data-reveal style="background:#0c0c0d;padding:40px">
          <span style="font:700 22px 'JetBrains Mono',monospace;color:#4d8b00">{s.n}</span>
          <h3 style="margin:18px 0 10px;font:700 26px 'Space Grotesk',sans-serif">{s.title}</h3>
          <p style="margin:0;font:400 15px/1.6 'Space Grotesk',sans-serif;color:rgba(245,244,241,.6)">
            {s.desc}
          </p>
        </div>
      ))
    }
  </div>
</section>
